# Salin file ini menjadi .env dan isi sesuai environment kamu

PORT=4000

# Koneksi PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ekspedisi_db

# Rahasia untuk menandatangani JWT - GANTI dengan string acak yang panjang di production
JWT_SECRET=ganti_dengan_secret_yang_sangat_rahasia
JWT_EXPIRES_IN=7d

# Prefix nomor resi, contoh: EKS -> EKS172345678901ID
RESI_PREFIX=EKS
